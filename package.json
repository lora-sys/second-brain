{
  "name": "second-brain",
  "version": "0.4.0-alpha",
  "private": true,
  "type": "module",
  "description": "Personal Cognitive OS — local-first Obsidian-backed second brain with Tauri shell, AI daily memory, and MCP agent interface",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:web": "node packages/web/src/server.mjs",
    "build:web": "echo 'no build step yet'",
    "dev:desktop": "cd packages/desktop && cargo tauri dev",
    "build:desktop": "cd packages/desktop && cargo tauri build",
    "check": "node --check packages/core/src/*.mjs && node --check packages/core/src/llm/*.js",
    "test:e2e": "playwright-cli run-code --filename recordings/e2e-demo.mjs"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jsdom": "^24.1.0",
    "marked": "^14.1.0"
  },
  "homepage": "https://github.com/lora-sys/second-brain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lora-sys/second-brain.git"
  },
  "bugs": {
    "url": "https://github.com/lora-sys/second-brain/issues"
  }
}
