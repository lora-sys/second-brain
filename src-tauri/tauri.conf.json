{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Second Brain",
  "version": "0.4.0",
  "identifier": "com.secondbrain.desktop",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:3939",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "第二大脑 · Second Brain",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": ""
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first Personal Cognitive OS",
    "longDescription": "Second Brain OS — a local-first Personal Cognitive Operating System that observes, relates, and reflects on your notes, tasks, projects, and links. Powered by your Obsidian Vault.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
