# Second Brain OS — environment configuration
# Copy to .env and fill in. .env is git-ignored.

# === LLM Provider (OpenAI-compatible) ===
# Get from https://platform.openai.com/api-keys
# Or use any OpenAI-compatible endpoint: Azure, Together, Groq, Ollama (openai mode), vLLM.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1   # default; change for self-hosted
OPENAI_MODEL=gpt-4o-mini                     # or gpt-4o, claude-3-5-sonnet via proxy, etc.
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=3

# === Agent (MCP server) ===
# Port for the local MCP server (v0.9+)
AGENT_PORT=3939

# === Daily Journal Agent (v0.5) ===
# When to auto-generate the daily journal: "00:00" midnight, "manual" only, "off"
DAILY_JOURNAL_TRIGGER=00:00
DAILY_JOURNAL_PROVIDER=openai
# Optional model override (defaults to OPENAI_MODEL)
DAILY_JOURNAL_MODEL=

# === Capture Layer (v0.5) ===
# File watcher: on / off
FILE_WATCHER_ENABLED=true
# Watch debounce (ms) — collapse rapid saves
FILE_WATCHER_DEBOUNCE_MS=500
# Webhook: require a shared secret (rotate periodically)
AGENT_WEBHOOK_SECRET=replace-with-random-string

# === Concurrency (v0.5) ===
# File lock timeout (ms) — fail if another writer holds the lock
VAULT_LOCK_TIMEOUT_MS=5000

# === Caching (v0.5) ===
# LLM response cache TTL (seconds). 0 = disabled.
LLM_CACHE_TTL=86400
# Vault read cache TTL (seconds). 0 = disabled.
VAULT_CACHE_TTL=60

# === Observability (v0.5) ===
# Log all AI tool calls to vault for audit
AI_AUDIT_LOG=true
# Path under vault for AI logs
AI_AUDIT_PATH=00-AI/audit

# === Safety (v0.9) ===
# Max AI tool calls per minute (0 = unlimited)
AI_RATE_LIMIT_PER_MIN=60
# Require explicit user opt-in for API calls
AI_REQUIRE_OPTIN=true
